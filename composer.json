{
    "name": "dynamik-dev/laravel-policy-engine",
    "description": "A Laravel-native scoped permissions package. Composable, contract-driven authorization that integrates with Gates, Policies, middleware, and Blade.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "permissions",
        "authorization",
        "roles",
        "policy",
        "rbac",
        "scoped-permissions"
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.27",
        "laravel/sanctum": "^4.3",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-mutate": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "DynamikDev\\PolicyEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DynamikDev\\PolicyEngine\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DynamikDev\\PolicyEngine\\PolicyEngineServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:pgsql": "DB_CONNECTION=pgsql vendor/bin/pest",
        "test:mysql": "DB_CONNECTION=mysql vendor/bin/pest",
        "test:all": [
            "@test",
            "@test:pgsql",
            "@test:mysql"
        ],
        "test:coverage": "vendor/bin/pest --coverage",
        "test:services": "docker compose -f docker-compose.test.yml up -d --wait",
        "test:down": "docker compose -f docker-compose.test.yml down -v"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
